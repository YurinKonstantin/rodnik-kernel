#!/bin/busybox sh
# Init ОС Родник

mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
mknod /dev/null c 1 3
mknod /dev/zero c 1 5
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts
mount -t tmpfs tmpfs /tmp
mount -t tmpfs tmpfs /run

echo "Rodnik OS starting..."

cat > /tmp/.xinitrc << 'XINIT'
#!/bin/sh
export DISPLAY=:0
exec /opt/rodnik/Rodnik.Compositor
XINIT
chmod +x /tmp/.xinitrc

if [ -f /usr/bin/Xorg ] && [ -f /usr/bin/xinit ]; then
    xinit /tmp/.xinitrc -- /usr/bin/Xorg :0 -config /etc/X11/xorg.conf &
    sleep 2
fi

if [ ! -e /tmp/.X11-unix/X0 ]; then
    /opt/rodnik/Rodnik.Compositor &
fi

/sbin/getty 38400 tty1 &

while true; do
    pidof Rodnik.Compositor > /dev/null || /opt/rodnik/Rodnik.Compositor &
    sleep 5
done
